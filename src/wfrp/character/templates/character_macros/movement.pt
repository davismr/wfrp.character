<div id="movement" class="border">
    <div class="row">
        <div class="col-md-12 caption">Movement</div>
    </div>
    <div class="row">
        <div class="col">Movement</div>
        <div class="col">${character.movement}</div>
        <div class="col">Walk</div>
        <div class="col">${character.movement * 2}</div>
        <div class="col">Run</div>
        <div class="col">${character.movement * 4}</div>
    </div>
</div>
