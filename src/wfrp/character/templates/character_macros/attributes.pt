<div id="attributes" class="border container">
    <div class="row caption">
        <div class="col-md-12">Characteristics</div>
    </div>
    <div class="row">
        <div class="col-md-2">&nbsp;</div>
        <div class="col">WS</div>
        <div class="col">BS</div>
        <div class="col">S</div>
        <div class="col">T</div>
        <div class="col">I</div>
        <div class="col">Ag</div>
        <div class="col">Dex</div>
        <div class="col">Int</div>
        <div class="col">WP</div>
        <div class="col">Fel</div>
    </div>
    <div class="row">
        <div class="col-md-2">Initial</div>
        <div class="col">${character.weapon_skill_initial}</div>
        <div class="col">${character.ballistic_skill_initial}</div>
        <div class="col">${character.strength_initial}</div>
        <div class="col">${character.toughness_initial}</div>
        <div class="col">${character.initiative_initial}</div>
        <div class="col">${character.agility_initial}</div>
        <div class="col">${character.dexterity_initial}</div>
        <div class="col">${character.intelligence_initial}</div>
        <div class="col">${character.willpower_initial}</div>
        <div class="col">${character.fellowship_initial}</div>
    </div>
    <div class="row">
        <div class="col-md-2">Advances</div>
        <div class="col">${character.weapon_skill_advances}</div>
        <div class="col">${character.ballistic_skill_advances}</div>
        <div class="col">${character.strength_advances}</div>
        <div class="col">${character.toughness_advances}</div>
        <div class="col">${character.initiative_advances}</div>
        <div class="col">${character.agility_advances}</div>
        <div class="col">${character.dexterity_advances}</div>
        <div class="col">${character.intelligence_advances}</div>
        <div class="col">${character.willpower_advances}</div>
        <div class="col">${character.fellowship_advances}</div>
    </div>
    <div class="row">
        <div class="col-md-2">Advances</div>
        <div class="col">${character.weapon_skill}</div>
        <div class="col">${character.ballistic_skill}</div>
        <div class="col">${character.strength}</div>
        <div class="col">${character.toughness}</div>
        <div class="col">${character.initiative}</div>
        <div class="col">${character.agility}</div>
        <div class="col">${character.dexterity}</div>
        <div class="col">${character.intelligence}</div>
        <div class="col">${character.willpower}</div>
        <div class="col">${character.fellowship}</div>
    </div>
</div>
